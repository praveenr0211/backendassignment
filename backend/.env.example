# ============================================
# Backend Environment Variables
# ============================================

# Database Configuration
# For development (SQLite):
# DATABASE_URL=sqlite:///./test.db

# For production (PostgreSQL on Render):
# Get your PostgreSQL URL from Render dashboard: Settings > Internal Database
# Format: postgresql://username:password@hostname:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/task_manager

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production (minimum 32 characters)
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long

# Debug Mode (set to False in production)
DEBUG=False

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_STR=/api/v1

# CORS Origins (comma-separated)
# For development:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
# For production on Render, add your frontend URL:
# CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Password Configuration
PASSWORD_MIN_LENGTH=8

# Application Settings
APP_NAME=Task Management API
APP_VERSION=1.0.0

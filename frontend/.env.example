# API Configuration
# For development (separate services):
# VITE_API_URL=http://localhost:8000

# For production (single web service):
# Leave empty or use relative path - will use same domain
# VITE_API_URL=/api

# For production (separate services):
# VITE_API_URL=https://your-backend-api.onrender.com

VITE_API_URL=http://localhost:8000

# Application Settings
VITE_APP_NAME=Task Management
